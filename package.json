{
  "name": "contribute-now",
  "version": "0.6.0",
  "description": "Developer CLI that automates git workflows — branching, syncing, committing, and PRs — with multi-workflow and commit convention support.",
  "type": "module",
  "bin": {
    "contrib": "dist/index.js",
    "contribute": "dist/index.js",
    "cn": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --target node --packages external",
    "cli": "bun run src/index.ts --",
    "dev": "bun src/index.ts",
    "test": "bun test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "landing:install": "bun install --cwd landing",
    "landing:dev": "bun run --cwd landing dev",
    "landing:build": "bun run --cwd landing build",
    "landing:preview": "bun run --cwd landing preview"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.0"
  },
  "keywords": [
    "git",
    "workflow",
    "squash-merge",
    "sync",
    "cli",
    "contribute",
    "fork",
    "dev-branch",
    "clean-commit"
  ],
  "author": "Waren Gonzaga",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/warengonzaga/contribute-now.git"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "@github/copilot-sdk": "^0.1.25",
    "@wgtechlabs/log-engine": "^2.3.1",
    "citty": "^0.1.6",
    "figlet": "^1.10.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/bun": "latest",
    "@types/figlet": "^1.7.0",
    "typescript": "^5.7.0"
  }
}
